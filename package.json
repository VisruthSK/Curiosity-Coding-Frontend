{
  "name": "curiosity-coding-frontend",
  "version": "0.2.0",
  "author": "Visruth Srimath Kandali",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:build:ci": "tauri build --config src-tauri/tauri.ci.conf.json",
    "desktop:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:e2e": "playwright test",
    "test:unit": "vitest run tests/unit",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/preact": "^6.0.1",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "astro": "^7.0.6",
    "d3-dsv": "^3.0.1",
    "preact": "^10.29.4",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
